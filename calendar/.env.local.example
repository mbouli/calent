NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# --- Local testing only (ignored in production builds) ---
# Set TESTING=true to auto-login the test user below under `next dev`, skipping
# the login screen. Has no effect in production (NODE_ENV guard). Defaults off.
TESTING=false
TEST_USER_EMAIL=
TEST_USER_PASSWORD=